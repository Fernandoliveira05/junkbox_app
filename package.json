{
  "name": "junkbox-backend",
  "version": "0.1.0",
  "description": "Backend OpenAPI for JunkBox, a music and album social catalog with AudD recognition.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "node scripts/seed-library.mjs",
    "seed:covers": "node scripts/fetch-real-covers.mjs",
    "test": "vitest run",
    "openapi:check": "redocly lint openapi.yaml"
  },
  "keywords": [
    "music",
    "albums",
    "openapi",
    "audd"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "js-yaml": "^4.1.0",
    "multer": "^2.0.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@redocly/cli": "^1.34.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.2",
    "@types/swagger-ui-express": "^4.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
